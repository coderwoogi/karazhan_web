APP_ENV=production
PORT=80
KARAZHAN_DEV_DOMAIN=karazhandev.kro.kr
KARAZHAN_PROD_DOMAIN=karazhan.kro.kr

# Production auth DB
KARAZHAN_AUTH_DSN=root:password@tcp(127.0.0.1:3306)/acore_auth

# Production characters DB
KARAZHAN_CHARACTERS_DSN=root:password@tcp(127.0.0.1:3306)/acore_characters

# Production update DB
KARAZHAN_UPDATE_DSN=root:password@tcp(127.0.0.1:3306)/update

# Optional: admin update menu can point to a separate production update DB.
# When empty, the update menu falls back to KARAZHAN_UPDATE_DSN.
# KARAZHAN_UPDATE_ADMIN_DSN=root:password@tcp(prod-db-host:3306)/update

# Production world DB
KARAZHAN_WORLD_DSN=root:password@tcp(127.0.0.1:3306)/acore_world

# SMTP settings for account recovery mails
KARAZHAN_SMTP_HOST=smtp.example.com
KARAZHAN_SMTP_PORT=587
KARAZHAN_SMTP_USERNAME=no-reply@example.com
KARAZHAN_SMTP_PASSWORD=app-password
KARAZHAN_SMTP_FROM_EMAIL=no-reply@example.com
KARAZHAN_SMTP_FROM_NAME=Karazhan
